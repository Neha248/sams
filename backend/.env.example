# 5001 = local npm dev (avoids Docker backend on 5000). Use 5000 only inside Docker.
PORT=5001
NODE_ENV=development
# Local npm dev (Mongo via docker-compose.mongo.yml): 127.0.0.1
# Full docker-compose stack: mongodb
MONGO_URI=mongodb://127.0.0.1:27017/attendance_system
JWT_SECRET=sams_super_secret_jwt_key_2026
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:5173
