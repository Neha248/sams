{
    "tabWidth": 4,
    "useTabs": false,

    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",

    "printWidth": 100,
    "bracketSpacing": true,
    "arrowParens": "always",

    "jsxSingleQuote": true,

    "endOfLine": "lf",

    "overrides": [
        {
            "files": "*.md",
            "options": {
                "proseWrap": "preserve"
            }
        },
        {
            "files": "*.json",
            "options": {
                "tabWidth": 4
            }
        },
        {
            "files": "*.yml",
            "options": {
                "tabWidth": 2
            }
        }
    ]
}